<?xml version="1.0"?>
<cdi xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://openlcb.org/schema/cdi/1/4/cdi.xsd">
	<identification>
		<manufacturer>TestCorp</manufacturer>
		<model>BasicDevice</model>
		<hardwareVersion>1.0</hardwareVersion>
		<softwareVersion>1.2.3</softwareVersion>
		<link ref="https://example.com/docs">Documentation</link>
	</identification>
	<acdi/> <!-- Test ACDI presence -->
	<segment origin="0" space="253">
		<name>Main Configuration</name>
		<description>General device settings.</description>
		<group>
			<name>Node Information</name>
			<string size="32">
				<name>Device Name</name>
				<description>A user-friendly name for this device.</description>
			</string>
			<string size="64">
				<name>Location</name>
				<description>Where the device is physically located.</description>
			</string>
			<int size="1" default="10">
				<name>Baud Rate Index</name>
				<description>Select a baud rate from the predefined options.</description>
			</int>
		</group>
	</segment>
</cdi>

